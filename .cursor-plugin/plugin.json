  "author": "AIGov maintainers",
  "homepage": "https://github.com/MonikaDvorackova/aigov-compliance-engine",
  "repository": "https://github.com/MonikaDvorackova/aigov-compliance-engine",
  "license": "UNLICENSED",
  "keywords": [
    "governance",
    "compliance",
    "ai-act",
    "evidence-pack",
    "audit",
    "mcp",
    "cursor",
    "govai-platform"
  ],
  "logo": "assets/logo.png",
  "rules": "rules",
  "skills": "skills",
  "mcpServers": {
    "aigov-local": {
      "command": "python3",
      "args": ["mcp/aigov_mcp_server.py", "mcp-stdio"],
      "env": {}
    },
    "govai-local": {
      "command": "python3",
      "args": ["mcp/govai_mcp_server.py", "mcp-stdio"],
      "env": {}
    }
  }
}
