{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aigov.dev/schemas/govai.policy.v1.schema.json",
  "title": "GovAI Policy (v1)",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "policy_id", "version", "created_at_utc", "issuer", "selectors", "inherits", "ingest_rules", "verdict_rules", "signatures"],
  "properties": {
    "schema": {
      "type": "string",
      "const": "govai.policy.v1"
    },
    "policy_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "version": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64
    },
    "created_at_utc": {
      "type": "string",
      "minLength": 20,
      "maxLength": 40,
      "description": "RFC3339 timestamp in UTC (e.g. 2026-01-01T00:00:00Z)."
    },
    "issuer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["issuer_id", "display_name"],
      "properties": {
        "issuer_id": { "type": "string", "minLength": 1, "maxLength": 128 },
        "display_name": { "type": "string", "minLength": 1, "maxLength": 128 },
        "contact": { "type": ["string", "null"], "maxLength": 256 }
      }
    },
    "selectors": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tenants", "environments"],
      "properties": {
        "tenants": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1, "maxLength": 128 },
          "description": "Tenant ids this policy applies to. Use '*' for all tenants only in dev/sandbox."
        },
        "environments": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "enum": ["dev", "staging", "prod"] }
        }
      }
    },
    "inherits": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["policy_id", "version", "digest_sha256"],
        "properties": {
          "policy_id": { "type": "string", "minLength": 1, "maxLength": 128 },
          "version": { "type": "string", "minLength": 1, "maxLength": 64 },
          "digest_sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$",
            "description": "SHA-256 over canonical policy bytes of the referenced policy."
          }
        }
      },
      "description": "Deterministic inheritance chain. Evaluators must merge in listed order and fail on conflicts."
    },
    "ingest_rules": {
      "type": "object",
      "additionalProperties": false,
      "required": ["unknown_event_types", "event_types"],
      "properties": {
        "unknown_event_types": {
          "type": "object",
          "additionalProperties": false,
          "required": ["behavior"],
          "properties": {
            "behavior": {
              "type": "string",
              "enum": ["reject", "allow"],
              "description": "Fail-closed default is 'reject' in staging/prod."
            }
          }
        },
        "event_types": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": false,
            "required": ["schema", "gates"],
            "properties": {
              "schema": {
                "type": "object",
                "description": "Event payload constraints (Phase 1: JSON-schema-ish subset)."
              },
              "gates": {
                "type": "array",
                "items": { "type": "object" },
                "description": "Cross-event deterministic gating constraints. Evaluators must be deterministic and fail-closed."
              }
            }
          },
          "description": "Per-event-type ingest policy."
        }
      }
    },
    "verdict_rules": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required_evidence_codes", "invalid_conditions"],
      "properties": {
        "required_evidence_codes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1, "maxLength": 128 }
        },
        "invalid_conditions": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["code", "description"],
            "properties": {
              "code": { "type": "string", "minLength": 1, "maxLength": 128 },
              "description": { "type": "string", "minLength": 1, "maxLength": 1024 }
            }
          }
        }
      }
    },
    "signatures": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "signer", "created_at_utc", "payload_digest_sha256", "signature"],
        "properties": {
          "kind": { "type": "string", "enum": ["sigstore", "ed25519", "x509"] },
          "signer": { "type": "string", "minLength": 1, "maxLength": 256 },
          "created_at_utc": { "type": "string", "minLength": 20, "maxLength": 40 },
          "expires_at_utc": { "type": ["string", "null"], "minLength": 20, "maxLength": 40 },
          "payload_digest_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
          "signature": {
            "type": "object",
            "additionalProperties": false,
            "required": ["encoding", "value"],
            "properties": {
              "encoding": { "type": "string", "enum": ["base64"] },
              "value": { "type": "string", "minLength": 16, "maxLength": 16384 }
            }
          },
          "sigstore": {
            "type": ["object", "null"],
            "additionalProperties": false,
            "properties": {
              "rekor_log_index": { "type": ["integer", "null"], "minimum": 0 },
              "rekor_uuid": { "type": ["string", "null"], "maxLength": 128 },
              "fulcio_issuer": { "type": ["string", "null"], "maxLength": 256 }
            }
          }
        }
      }
    }
  }
}

