      "expected_verdict": "BLOCKED",
      "injected_violation": true,
      "should_pass": false
    },
    {
      "scenario_name": "missing_evidence_pack",
      "expected_verdict": "BLOCKED",
      "injected_violation": true,
      "should_pass": false
    },
    {
      "scenario_name": "failed_compliance_evaluation",
      "expected_verdict": "INVALID",
      "injected_violation": true,
      "should_pass": false
    },
    {
      "scenario_name": "missing_approval_record",
      "expected_verdict": "BLOCKED",
      "injected_violation": true,
      "should_pass": false
