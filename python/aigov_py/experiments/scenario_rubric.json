    "digest_mismatch_export_only": "Only export_digest_match is false; events_content_sha256_match remains true.",
    "duplicated_evidence_event_idempotent": "Duplicate events are content-identical; digest and artifact-bound verification still succeed.",
    "duplicated_evidence_event_conflicting": "Non-idempotent duplicate breaks artifact-bound verification while other pipeline fields remain superficially satisfied."
